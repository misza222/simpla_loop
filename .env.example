# OpenAI Configuration for Agentic Loops

# Required: Your OpenAI API key
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Custom API base URL (for gateways/proxies)
# Leave unset to use default: https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Model to use (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional: Max retries for instructor validation (default: 3)
# OPENAI_MAX_RETRIES=3
